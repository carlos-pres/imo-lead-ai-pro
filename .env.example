PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/database
PGSSLMODE=require
JWT_SECRET=replace_with_a_long_random_secret
# Legacy fallback used by older integrations. Keep aligned with JWT_SECRET if needed.
SESSION_SECRET=replace_with_a_long_random_secret

# AI provider: use OpenAI or OpenRouter, not both unless intentionally configured.
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=
AI_INTEGRATIONS_OPENROUTER_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_HEAVY_MODEL=gpt-4o
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3.1
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

DEFAULT_PLAN_ID=pro
APP_BASE_URL=https://your-app.up.railway.app
CORS_ORIGIN=https://your-app.up.railway.app
NODE_ENV=production
# Reverse proxy trust (Railway defaults to 1 hop automatically when unset in production).
# Optional values: true, false, 1, 2, loopback, linklocal, uniquelocal.
TRUST_PROXY=
ADMIN_BOOTSTRAP_PASSWORD=replace_with_a_strong_admin_password
ADMIN_CONTACT_EMAIL=carlospsantos19820@gmail.com
PRIVACY_CONTACT_EMAIL=carlospsantos19820@gmail.com
ENABLE_PUBLIC_DEMO_ACCOUNTS=false
VITE_ENABLE_PUBLIC_DEMO=false
VITE_PRIVACY_CONTACT_EMAIL=carlospsantos19820@gmail.com
# Public marketing visual identity: "original" (default) | "current"
VITE_MARKETING_VISUAL_IDENTITY=original

# Set to true to disable external AI calls even if API keys are configured.
DISABLE_EXTERNAL_AI=false

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=ImoLead AI Pro
